# The dashboard reads these from the environment. Locally, copy to `.env` and fill in values.
# On Azure App Service, set the same keys under Environment variables (App settings).

# ---------------------------------------------------------------------------
# Databricks SQL warehouse — the dashboard connects directly, no API in between.
# ---------------------------------------------------------------------------
# Workspace host, no `https://` prefix. Example: adb-1234567890.12.azuredatabricks.net
DATABRICKS_HOST=
# SQL warehouse HTTP path, from "Connection details" on the warehouse page.
# Example: /sql/1.0/warehouses/abcdef1234567890
DATABRICKS_HTTP_PATH=
# Personal access token with BI Tools scope (or `sql` scope).
DATABRICKS_TOKEN=

# ---------------------------------------------------------------------------
# Unity Catalog + allowlist
# ---------------------------------------------------------------------------
GEMS_CATALOG=gems_catalog
GEMS_SCHEMA=gold_v1
# Comma-separated table names inside GEMS_CATALOG.GEMS_SCHEMA that users may query.
ALLOWED_TABLES=goldanimalcharacteristics,goldbodyweight,goldcontributor
# Hard upper bound on rows returned by any query (full-table CSV or /query wrap).
MAX_EXPORT_ROWS=100000
# Cap on rows loaded into the Modeling page.
MAX_MODEL_ROWS=20000

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
# Model used by the plot/model interpreters (short, cheap prompts).
OPENAI_MODEL=gpt-4o-mini
# Model used by the Chat page (tool-calling agent). Set to your current flagship;
# gpt-4o is a safe default.
OPENAI_CHAT_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Azure Table Storage.
# The dashboard uses this for API-key records. Use the same values in the API
# App Service so FastAPI can validate keys generated here.
# ---------------------------------------------------------------------------
AZURE_TABLES_CONNECTION_STRING=
AZURE_API_KEYS_TABLE=gemsApiKeys
API_KEY_PEPPER=change-me-to-a-long-random-server-secret

# Public FastAPI base URL shown on the API Access page.
GEMS_API_BASE_URL=https://YOUR-GEMS-API.azurewebsites.net

# ---------------------------------------------------------------------------
# Local-only fallback when running outside Azure (Easy Auth headers not present).
# ---------------------------------------------------------------------------
LOCAL_DEV_USER=local-dev@example.com

# ---------------------------------------------------------------------------
# In-app allowlist (enforced AFTER Auth0/Easy Auth sign-in). A user is allowed if
# their email/UPN is in ALLOWED_USERS, OR their domain is in ALLOWED_DOMAINS.
# Leave BOTH blank to allow any signed-in user.
# ---------------------------------------------------------------------------
# Comma-separated exact emails/UPNs.
ALLOWED_USERS=
# Comma-separated email domains (no "@"). Example: cornell.edu,nmbu.no
ALLOWED_DOMAINS=
