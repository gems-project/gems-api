# Copy to .env in this folder (never commit .env). See README.md.

# Databricks SQL warehouse (Connection details in Databricks UI)
DATABRICKS_HOST=adb-xxxxxxxx.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxx
DATABRICKS_TOKEN=dapi-xxxxxxxx

# Unity Catalog location of gold tables
GEMS_CATALOG=gems_catalog
GEMS_SCHEMA=gold_v1

# Per-user API keys generated from the dashboard.
# Use the same storage connection string/table/pepper in the dashboard and API App Services.
AZURE_TABLES_CONNECTION_STRING=
AZURE_API_KEYS_TABLE=gemsApiKeys
API_KEY_PEPPER=change-me-to-a-long-random-server-secret

# Comma-separated table names only (no catalog.schema) — must match real gold table names
ALLOWED_TABLES=goldanimalcharacteristics,goldbodyweight

# Optional: mirror dashboard data-access allowlist so removed users' API keys stop working.
ALLOWED_USERS=
ALLOWED_DOMAINS=

# Safety cap per export (increase if needed)
MAX_EXPORT_ROWS=100000